      "instances": [
        {
          "schema_version": 2,
          "attributes": {
            "atomic": true,
            "chart": "tyk-oss",
            "cleanup_on_fail": false,
            "create_namespace": false,
            "dependency_update": false,
            "description": null,
            "devel": null,
            "disable_crd_hooks": false,
            "disable_openapi_validation": false,
            "disable_webhooks": false,
            "force_update": false,
            "id": "tyk",
            "keyring": null,
            "lint": false,
            "manifest": null,
            "max_history": 0,
            "metadata": {
              "app_version": "",
              "chart": "tyk-oss",
              "first_deployed": 1771873564,
              "last_deployed": 1771905775,
              "name": "tyk",
              "namespace": "tyk",
              "notes": "Thank you for installing Tyk OSS Chart. Your release is named tyk.\nAt this point, Tyk Gateway is fully installed and should be accessible.\n\nTo quickly test everything is ok, you can port-forward Tyk Gateway pod:\n    kubectl port-forward --namespace tyk service/gateway-svc-tyk-tyk-gateway 8080:8080\n    curl localhost:8080/hello\n\n=== API Secret (TYK_GW_SECRET) ===\n    export TYK_GW_SECRET=$(kubectl get secrets --namespace tyk secrets-tyk-tyk-gateway -o jsonpath=\"{.data.APISecret}\" | base64 --decode)\n\n===================================================\n  Manage Ingress resources and APIs on Kubernetes\n===================================================\nYou might want to install Tyk Operator next to manage Ingress resources or manage your APIs.\nPlease check Tyk Operator documentation at https://tyk.io/docs/tyk-operator/\n\n=== Tyk Operator Secret (tyk-operator-conf) ===\nThe `tyk-operator-conf` secret, required for Tyk Operator to establish a connection with Tyk Gateway, is generated in the tyk namespace.\n\nIf API Secret of Tyk Gateway has configured via `global.secret.useSecretName` field, ensure that the `TYK_AUTH` field in the `tyk-operator-conf` secret contains the API secret of Tyk Gateway. This step ensures that Tyk Operator correctly identifies the API secret.\n\n    NOTE: After updating `tyk-operator-conf`, make sure that Tyk Operator pod is restarted.\n\n\nThank you for installing Tyk Gateway Chart. Your release is named 'tyk'.\nAt this point, Tyk Gateway is fully installed and should be accessible.\n\nTo quickly test everything is ok, you can port-forward Tyk Gateway service:\n\n    kubectl port-forward service/gateway-svc-tyk-tyk-gateway --namespace tyk 8080:8080\n    curl http://localhost:8080/hello\n\n===================================================\n  Manage Ingress resources and APIs on Kubernetes\n===================================================\nYou might want to install Tyk Operator next to manage Ingress resources or manage your APIs.\nPlease check Tyk Operator documentation at https://tyk.io/docs/tyk-operator/\n",
              "revision": 4,
              "values": "{\"global\":{\"components\":{\"pump\":false},\"redis\":{\"addrs\":[\"tyk-redis.tyk.svc:6379\"],\"pass\":\"topsecretpassword\"},\"storageType\":\"redis\"},\"tyk-gateway\":{\"gateway\":{\"extraVolumeMounts\":[{\"mountPath\":\"/mnt/tyk-gateway/apps\",\"name\":\"tyk-api-definitions\",\"readOnly\":true}],\"extraVolumes\":[{\"configMap\":{\"name\":\"tyk-api-definitions\"},\"name\":\"tyk-api-definitions\"}],\"image\":{\"tag\":\"v5.8.11\"},\"kind\":\"Deployment\",\"nodeSelector\":{\"node\":\"tyk\"},\"replicaCount\":1,\"resources\":{},\"service\":{\"externalTrafficPolicy\":\"Local\",\"type\":\"ClusterIP\"},\"tolerations\":[{\"effect\":\"NoSchedule\",\"key\":\"node\",\"operator\":\"Equal\",\"value\":\"tyk\"}],\"tykConfig\":{\"app_path\":\"/mnt/tyk-gateway/apps\",\"close_connections\":false,\"enable_analytics\":true,\"enable_jsvm\":false,\"enable_non_transactional_rate_limiter\":true,\"hash_keys\":false,\"max_idle_connections_per_host\":1000,\"opentelemetry\":{\"enabled\":true,\"endpoint\":\"opentelemetry-collector.dependencies.svc:4317\",\"exporter\":\"grpc\",\"sampling\":{\"rate\":\"0.1\",\"type\":\"TraceIDRatioBased\"}}}}}}",
              "version": "5.0.0"
            },
