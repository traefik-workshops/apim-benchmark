ase\"\n  \"username\": \"postgres\"\n\"management\":\n  \"type\": \"jdbc\"\n\"portal\":\n  \"deployment\":\n    \"nodeSelector\":\n      \"node\": \"gravitee\"\n    \"tolerations\":\n    - \"effect\": \"NoSchedule\"\n      \"key\": \"node\"\n      \"operator\": \"Equal\"\n      \"value\": \"gravitee\"\n  \"ingress\":\n    \"hosts\":\n    - \"portal.example.com\"\n  \"resources\": null\n\"ratelimit\":\n  \"type\": \"redis\"\n\"ui\":\n  \"deployment\":\n    \"nodeSelector\":\n      \"node\": \"gravitee\"\n    \"tolerations\":\n    - \"effect\": \"NoSchedule\"\n      \"key\": \"node\"\n      \"operator\": \"Equal\"\n      \"value\": \"gravitee\"\n  \"resources\": null\n"
            ],
