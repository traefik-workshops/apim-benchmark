            "metadata": {
              "app_version": "3.9",
              "chart": "ingress",
              "first_deployed": 1771876893,
              "last_deployed": 1771905774,
              "name": "kong",
              "namespace": "kong",
              "notes": "To connect to Kong, please execute the following commands:\nexport PROXY_IP=${HOST}:${PORT}\ncurl $PROXY_IP\n\nOnce installed, please follow along the getting started guide to start using\nKong: https://docs.konghq.com/kubernetes-ingress-controller/latest/guides/getting-started/\n\n\nTo connect to Kong, please execute the following commands:\n\nHOST=$(kubectl get svc --namespace kong kong-controller-proxy -o jsonpath='{.status.loadBalancer.ingress[0].ip}')\nPORT=$(kubectl get svc --namespace kong kong-controller-proxy -o jsonpath='{.spec.ports[0].port}')\nexport PROXY_IP=${HOST}:${PORT}\ncurl $PROXY_IP\n\nOnce installed, please follow along the getting started guide to start using\nKong: https://docs.konghq.com/kubernetes-ingress-controller/latest/guides/getting-started/\n\nWARNING: Kong Manager will not be functional because the Admin API is not\nenabled. Setting both .admin.enabled and .admin.http.enabled and/or\n.admin.tls.enabled to true to enable the Admin API over HTTP/TLS.\n\n",
              "revision": 3,
              "values": "{\"controller\":{\"deployment\":{\"kong\":{\"enabled\":false}},\"ingressController\":{\"enabled\":true,\"gatewayDiscovery\":{\"enabled\":true,\"generateAdminApiService\":true},\"watchNamespaces\":[\"kong\"]},\"nodeSelector\":{\"node\":\"kong\"},\"resources\":{},\"tolerations\":[{\"effect\":\"NoSchedule\",\"key\":\"node\",\"operator\":\"Equal\",\"value\":\"kong\"}]},\"gateway\":{\"admin\":{\"clusterIP\":\"None\",\"enabled\":true,\"type\":\"ClusterIP\"},\"enabled\":true,\"env\":{\"database\":\"off\",\"nginx_http_keepalive_requests\":\"999999\",\"nginx_worker_processes\":\"auto\",\"proxy_access_log\":\"off\",\"role\":\"traditional\",\"tracing_instrumentations\":\"all\",\"tracing_sampling_rate\":\"0.1\",\"upstream_keepalive_max_requests\":\"999999\"},\"image\":{\"tag\":\"3.9.1\"},\"ingressController\":{\"enabled\":false},\"nodeSelector\":{\"node\":\"kong\"},\"proxy\":{\"type\":\"ClusterIP\"},\"replicaCount\":1,\"resources\":{},\"service\":{\"type\":\"ClusterIP\"},\"tolerations\":[{\"effect\":\"NoSchedule\",\"key\":\"node\",\"operator\":\"Equal\",\"value\":\"kong\"}]}}",
              "version": "0.22.0"
            },
            "name": "kong",
            "namespace": "kong",
            "pass_credentials": false,
            "postrender": null,
            "recreate_pods": false,
