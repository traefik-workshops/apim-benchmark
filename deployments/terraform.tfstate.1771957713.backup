      "module": "module.dependencies.module.keycloak[0]",
      "mode": "managed",
      "type": "kubernetes_job_v1",
      "name": "fetch_tokens",
      "provider": "provider[\"registry.terraform.io/hashicorp/kubernetes\"]",
      "instances": [
        {
          "schema_version": 1,
          "attributes": {
            "id": "dependencies/fetch-keycloak-tokens",
            "metadata": [
              {
                "annotations": {},
                "generate_name": "",
                "generation": 1,
                "labels": {
                  "app": "token-fetcher"
                },
                "name": "fetch-keycloak-tokens",
                "namespace": "dependencies",
                "resource_version": "334657",
                "uid": "504607b3-ed74-41a7-9333-9f41f1b229e1"
              }
            ],
            "spec": [
              {
                "active_deadline_seconds": 0,
                "backoff_limit": 4,
                "backoff_limit_per_index": 0,
                "completion_mode": "NonIndexed",
                "completions": 1,
                "manual_selector": false,
                "max_failed_indexes": 0,
                "parallelism": 1,
                "pod_failure_policy": [],
                "selector": [
                  {
                    "match_expressions": [],
                    "match_labels": null
                  }
                ],
                "template": [
                  {
                    "metadata": [
                      {
                        "annotations": {},
                        "generate_name": "",
                        "generation": 0,
                        "labels": {
                          "app": "token-fetcher"
                        },
                        "name": "",
                        "resource_version": "",
                        "uid": ""
                      }
                    ],
                    "spec": [
                      {
                        "active_deadline_seconds": 0,
                        "affinity": [],
                        "automount_service_account_token": true,
                        "container": [
                          {
                            "args": [
                              "set -e\n# Wait for internal DNS to resolve\nuntil getent hosts keycloak-service; do echo \"waiting for dns...\"; sleep 2; done\n            \nUSERS_JSON='[{\"password\":\"password\",\"username\":\"user0@test.com\"},{\"password\":\"password\",\"username\":\"user1@test.com\"},{\"password\":\"password\",\"username\":\"user2@test.com\"},{\"password\":\"password\",\"username\":\"user3@test.com\"},{\"password\":\"password\",\"username\":\"user4@test.com\"},{\"password\":\"password\",\"username\":\"user5@test.com\"},{\"password\":\"password\",\"username\":\"user6@test.com\"},{\"password\":\"password\",\"username\":\"user7@test.com\"},{\"password\":\"password\",\"username\":\"user8@test.com\"},{\"password\":\"password\",\"username\":\"user9@test.com\"}]'\n            \n# Use jq to iterate and fetch tokens\necho \"$USERS_JSON\" | jq -c '.[]' | while read -r user; do\n  USERNAME=$(echo \"$user\" | jq -r '.username')\n  PASSWORD=$(echo \"$user\" | jq -r '.password')\n              \n  TOKEN=$(curl -sk -X POST \"http://keycloak-service:8080/realms/traefik/protocol/openid-connect/token\" \\\n    -H \"Content-Type: application/x-www-form-urlencoded\" \\\n    -d \"client_id=traefik\" \\\n    -d \"grant_type=password\" \\\n    -d \"client_secret=NoTgoLZpbrr5QvbNDIRIvmZOhe9wI0r0\" \\\n    -d \"scope=openid\" \\\n    -d \"username=$USERNAME\" \\\n    -d \"password=$PASSWORD\" | jq -r '.access_token')\n                \n  if [ \"$TOKEN\" != \"null\" ] \u0026\u0026 [ -n \"$TOKEN\" ]; then\n    # Safe JSON construction\n    echo \"{\\\"key\\\": \\\"$USERNAME\\\", \\\"value\\\": \\\"$TOKEN\\\"}\"\n  fi\ndone | jq -n -c 'reduce inputs as $i ({}; .[$i.key] = $i.value)'\n"
                            ],
                            "command": [
                              "/bin/sh",
                              "-c"
                            ],
                            "env": [],
                            "env_from": [],
                            "image": "badouralix/curl-jq",
                            "image_pull_policy": "Always",
                            "lifecycle": [],
                            "liveness_probe": [],
