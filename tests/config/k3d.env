# k3d local test configuration — lightweight defaults
# Override any of these by exporting env vars before running make.

# Test execution
EXECUTOR=constant-arrival-rate
RATE=100
VIRTUAL_USERS=10
DURATION=1
DURATION_UNIT=m
PARALLELISM=1
RAMPING_STEPS=10
FORTIO_OPTIONS=size=20
KEY_COUNT=10

# Service topology
ROUTE_COUNT=1
HOST_COUNT=1
APP_COUNT=1

# Auth — type enum: disabled | token_postgres | token_iac | jwt_hmac | jwt_keycloak
AUTH_TYPE=disabled

# TLS
USE_TLS=false

# Observability (OTLP only — no Prometheus, no gateway-side sampling)
OTEL_METRICS_ENABLED=false
OTEL_LOGS_ENABLED=false
OTEL_TRACES_ENABLED=false

# Rate limiting & quota
QUOTA_ENABLED=false
QUOTA_RATE=999999
QUOTA_PER=3600
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RATE=999999
RATE_LIMIT_PER=60

# Header injection
HEADER_INJ_REQ=false
HEADER_INJ_RES=false

# Provider-specific
TYK_AUTH=
