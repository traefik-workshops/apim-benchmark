# Cloud test configuration — production-grade loads

# Test execution
EXECUTOR=constant-arrival-rate
RATE=20000
VIRTUAL_USERS=50
DURATION=15
PARALLELISM=1
RAMPING_STEPS=10
FORTIO_OPTIONS=size=20
KEY_COUNT=100

# Service topology
ROUTE_COUNT=1
HOST_COUNT=1
APP_COUNT=1

# Middleware (all disabled for baseline)
AUTH_ENABLED=false
AUTH_TYPE=
ANALYTICS_DB_ENABLED=false
ANALYTICS_PROM_ENABLED=false
QUOTA_ENABLED=false
QUOTA_RATE=999999
QUOTA_PER=3600
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RATE=999999
RATE_LIMIT_PER=60
OTEL_ENABLED=false
OTEL_SAMPLING_RATIO=
HEADER_INJ_REQ=false
HEADER_INJ_RES=false
TYK_AUTH=
